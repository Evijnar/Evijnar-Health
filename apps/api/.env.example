# apps/api/.env.example
# IMPORTANT: This is a template file. Never commit actual secrets.
# Use ./setup.sh to generate local .env files with placeholder values
# For production, use GitHub Organization Secrets (see docs/GITHUB_SECRETS_SETUP.md)

NODE_ENV=development

# Database (use placeholder values for local development)
DATABASE_URL=postgresql://evijnar_dev:dev_password_placeholder@localhost:5432/evijnar_dev

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_VERSION=v1
SECRET_KEY=dev_secret_key_placeholder_do_not_use_in_production

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Authentication (generate real keys for production)
JWT_SECRET=dev_jwt_secret_placeholder_do_not_use_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Encryption (for sensitive patient data)
# Generate for production: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY_PATIENT_DATA=dev_encryption_key_placeholder_generate_for_production
ENCRYPTION_KEY_PHARMA_DATA=dev_encryption_key_placeholder_generate_for_production

# External APIs (replace with your credentials)
GOOGLE_MAPS_API_KEY=dev_google_maps_key_replace_with_actual
TWILIO_ACCOUNT_SID=dev_twilio_sid_replace_with_actual
TWILIO_AUTH_TOKEN=dev_twilio_token_replace_with_actual

# HIPAA Compliance
HIPAA_AUDIT_LOG_ENABLED=true
HIPAA_AUDIT_WEBHOOK_URL=https://audit.example.com/webhook

# Feature Flags
FEATURE_RECOVERY_BRIDGE_ENABLED=true
FEATURE_RURAL_FINANCING_ENABLED=true

# Data Ingestion - Evijnar Health AI & Caching
# Optional JSON knowledge base endpoint for advanced normalization
EVIJNAR_AI_KB_URL=
REDIS_URL=redis://localhost:6379
INGEST_BATCH_SIZE=100
INGEST_MAX_CONCURRENT_LLM=5

